{
  # Comment.nvim — toggle comments. `gcc` toggles the current line, `gc{motion}`
  # (and `gc` in visual) toggles a range, `gbc`/`gb{motion}` for block comments.
  # It derives the comment syntax from treesitter, so JSX/TSX and other embedded
  # languages comment correctly.
  plugins.comment.enable = true;
}
